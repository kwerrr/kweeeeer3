# Функция для получения флор-цены с Getgems
async def get_nft_floor_price(nft_link: str) -> Optional[float]:
    """
    Получает флор-цену NFT с Getgems.io
    Поддерживает форматы:
    - https://getgems.io/collection/EQC7X2fv8gU4kTLXoDxR2Gm9iZ3F6Qq5W4pX8yZ9nYxL/MyNFT-1
    - https://getgems.io/nft/EQC7X2fv8gU4kTLXoDxR2Gm9iZ3F6Qq5W4pX8yZ9nYxL
    - t.me/nft/COLLECTION_NAME/NFT_NAME
    """
    try:
        # Извлекаем адрес коллекции или NFT из ссылки
        collection_address = None
        nft_name = None
        
        # Паттерн для getgems.io
        getgems_pattern = r'getgems\.io/(?:collection|nft)/([a-zA-Z0-9_-]+)(?:/([a-zA-Z0-9_-]+))?'
        match = re.search(getgems_pattern, nft_link)
        
        if match:
            collection_address = match.group(1)
            nft_name = match.group(2)
        
        # Паттерн для t.me/nft/
        tme_pattern = r't\.me/nft/([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)'
        match = re.search(tme_pattern, nft_link)
        
        if match:
            collection_address = match.group(1)
            nft_name = match.group(2)
        
        if not collection_address:
            logging.warning(f"Could not extract collection from link: {nft_link}")
            return None
        
        # Формируем API запрос к Getgems
        # Используем публичное API Getgems для получения информации о коллекции
        api_url = f"https://api.getgems.io/graphql"
        
        # GraphQL запрос для получения флор-цены коллекции
        query = """
        query Collection($address: String!) {
          collection(address: $address) {
            floorPrice
            name
          }
        }
        """
        
        async with aiohttp.ClientSession() as session:
            async with session.post(api_url, json={
                'query': query,
                'variables': {'address': collection_address}
            }) as response:
                if response.status == 200:
                    data = await response.json()
                    if 'data' in data and data['data'] and data['data']['collection']:
                        floor_price = data['data']['collection'].get('floorPrice')
                        if floor_price:
                            # Конвертируем из наноTON в TON
                            return float(floor_price) / 1_000_000_000
    except Exception as e:
        logging.error(f"Error getting NFT floor price: {e}")
    
    return None

# Функция для форматирования флор-цены
def format_floor_price(price: Optional[float]) -> str:
    if price is None:
        return "Не удалось определить"
    return f"{price:.2f} TON"

# База данных (в реальном проекте используйте PostgreSQL/MySQL)
class Database:
    def __init__(self):
        self.users: Dict[int, dict] = {}
        self.deals: Dict[str, dict] = {}
        self.banned_users: List[int] = []  # Список забаненных пользователей
        self.pending_logs: Dict[str, datetime] = {}  # Для отслеживания отправки логов через 5 минут
        
    def get_user(self, user_id: int) -> dict:
        # Проверяем, забанен ли пользователь
        if user_id in self.banned_users:
            return {
                'user_id': user_id,
                'username': None,
                'first_name': None,
                'role': UserRole.BANNED.value,
                'balance': 0,
                'total_turnover': 0,
                'successful_deals': 0,
                'created_at': datetime.now().isoformat(),
                'deals': [],
                'requisites': {
                    'card': None,
                    'phone': None,
                    'bank': None,  # Добавлено поле для банка
                    'stars': None,
                    'ton_wallet': None
                },
                'has_requisites': False
            }
        
        if user_id not in self.users:
            # Проверяем, является ли пользователь админом
            role = UserRole.ADMIN.value if str(user_id) in ADMIN_IDS else UserRole.USER.value
            self.users[user_id] = {
                'user_id': user_id,
                'username': None,
                'first_name': None,
                'role': role,
                'balance': 0,
                'total_turnover': 0,
                'successful_deals': 0,
                'created_at': datetime.now().isoformat(),
                'deals': [],
                'requisites': {
                    'card': None,
                    'phone': None,
                    'bank': None,  # Добавлено поле для банка
                    'stars': None,
                    'ton_wallet': None
                },
                'has_requisites': False
            }
        return self.users[user_id]
    
    def update_user(self, user_id: int, **kwargs):
        if user_id in self.users:
            self.users[user_id].update(kwargs)
    
    def add_requisite(self, user_id: int, type: str, value: str):
        if user_id in self.users:
            self.users[user_id]['requisites'][type] = value
            # Проверяем, есть ли хотя бы один реквизит
            req = self.users[user_id]['requisites']
            self.users[user_id]['has_requisites'] = bool(req['card'] or req['phone'] or req['stars'] or req['ton_wallet'])
    
    def get_requisites(self, user_id: int) -> dict:
        return self.users.get(user_id, {}).get('requisites', {'card': None, 'phone': None, 'bank': None, 'stars': None, 'ton_wallet': None})
    
    def create_deal(self, creator_id: int, currency: str, amount: float, description: str) -> str:
        # Генерируем случайный уникальный ID с символом #
        while True:
            random_part = secrets.token_hex(4).upper()
            deal_id = f"#{random_part}"
            if deal_id not in self.deals:
                break
        
        self.deals[deal_id] = {
            'deal_id': deal_id,
            'creator_id': creator_id,
            'buyer_id': None,
            'currency': currency,
            'amount': amount,
            'description': description,
            'status': DealStatus.PENDING.value,
            'created_at': datetime.now().isoformat(),
            'paid_at': None,
            'completed_at': None,
            'nft_proof': None,
            'gift_sent_at': None,
            'floor_price': None,  # Добавлено поле для хранения флор-цены
            'log_scheduled': False  # Флаг для отслеживания запланированной отправки лога
        }
        
        # Добавляем сделку в список пользователя
        self.users[creator_id]['deals'].append(deal_id)
        
        return deal_id
    
    def get_deal(self, deal_id: str) -> Optional[dict]:
        return self.deals.get(deal_id)
    
    def update_deal(self, deal_id: str, **kwargs):
        if deal_id in self.deals:
            self.deals[deal_id].update(kwargs)
    
    def get_user_deals(self, user_id: int) -> List[dict]:
        user_deals = []
        for deal_id, deal in self.deals.items():
            if deal['creator_id'] == user_id or deal.get('buyer_id') == user_id:
                user_deals.append(deal)
        return user_deals
    
    def get_all_deals(self) -> List[dict]:
        return list(self.deals.values())
    
    def get_pending_deals(self) -> List[dict]:
        return [d for d in self.deals.values() if d['status'] == DealStatus.PENDING.value]
    
    def get_active_deals(self) -> List[dict]:
        active_statuses = [DealStatus.PENDING.value, DealStatus.PAID.value, DealStatus.NFT_SENT.value]
        return [d for d in self.deals.values() if d['status'] in active_statuses]
    
    # Новые методы для работы с баном
    def ban_user(self, user_id: int) -> bool:
        if user_id not in self.banned_users and str(user_id) not in ADMIN_IDS:
            self.banned_users.append(user_id)
            # Если пользователь есть в базе, меняем его роль
            if user_id in self.users:
                self.users[user_id]['role'] = UserRole.BANNED.value
            return True
        return False
    
    def unban_user(self, user_id: int) -> bool:
        if user_id in self.banned_users:
            self.banned_users.remove(user_id)
            # Восстанавливаем роль
            if user_id in self.users:
                self.users[user_id]['role'] = UserRole.USER.value
            return True
        return False
    
    def is_banned(self, user_id: int) -> bool:
        return user_id in self.banned_users
    
    def get_banned_users(self) -> List[int]:
        return self.banned_users

