@dp.message(DealCreation.entering_description)
async def process_description(message: types.Message, state: FSMContext):
    user_id = message.from_user.id
    
    # Проверяем, не забанен ли пользователь
    if db.is_banned(user_id):
        await message.answer("🚫 Вы забанены в боте")
        await state.clear()
        return
    
    description = message.text
    await state.update_data(description=description)
    
    data = await state.get_data()
    currency = data['currency']
    amount = data['amount']
    
    # Проверяем наличие необходимых реквизитов в зависимости от валюты
    user = db.get_user(user_id)
    req = user['requisites']
    
    if currency == 'STARS' and not req['stars']:
        await message.answer("❌ Для создания сделки в STARS необходимо добавить STARS реквизиты в разделе 'Мои реквизиты'")
        await state.clear()
        return
    elif currency == 'RUB' and not (req['card'] or req['phone']):
        await message.answer("❌ Для создания сделки в RUB необходимо добавить карту или телефон (СБП) в разделе 'Мои реквизиты'")
        await state.clear()
        return
    elif currency == 'TON' and not req['ton_wallet']:
        await message.answer("❌ Для создания сделки в TON необходимо добавить TON кошелек в разделе 'Мои реквизиты'")
        await state.clear()
        return
    
    confirm_text = (
        f"{hbold('Подтверждение создания сделки:')}\n\n"
        f"💱 Валюта: {SUPPORTED_CURRENCIES[currency]}\n"
        f"💰 Сумма: {amount}\n"
        f"📝 Описание: {description}\n\n"
        f"Всё верно?"
